# HTTP port for NestJS (default 3101; Next.js dev uses 3100 in this repo)
PORT=3101

# MySQL connection (OSPanel example: host from project domain, empty password)
DATABASE_HOST=mysql-8.0.local
DATABASE_PORT=3306
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_NAME=lead-tracker

# Comma-separated browser origins allowed by CORS (no trailing slashes)
CORS_ORIGIN=http://localhost:3100

# Optional: set to production in deployed environments
# NODE_ENV=development
